# Copy this file to .env before running docker compose.
# Use strong random values for every secret entry.

POSTGRES_USER=nextplay
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=nextplay
DATABASE_URL=postgres://nextplay:replace-with-a-strong-postgres-password@postgres:5432/nextplay?sslmode=disable
LOCAL_DATABASE_URL=postgres://nextplay:replace-with-a-strong-postgres-password@localhost:5432/nextplay?sslmode=disable

JWT_SECRET=replace-with-a-32-byte-random-secret
PASSWORD_PEPPER=replace-with-a-32-byte-random-pepper
GATEWAY_SERVICE_TOKEN=replace-with-a-32-byte-random-service-token

IGDB_CLIENT_ID=replace-with-your-igdb-client-id
IGDB_CLIENT_SECRET=replace-with-your-twitch-client-secret
IGDB_ACCESS_TOKEN=replace-with-your-igdb-access-token

